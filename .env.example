# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME="Caros"
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=your-secret-key-min-32-chars-change-in-production

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_ats
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
LLM_PRIMARY_MODEL=gpt-4o
LLM_FALLBACK_MODEL=claude-3-5-sonnet-20241022
EMBEDDING_MODEL=text-embedding-3-small

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=ai-ats-files
R2_PUBLIC_URL=https://your-bucket.r2.cloudflarestorage.com

# ── Observability ──────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=https://...@sentry.io/...

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── Encryption ────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=your-fernet-key-generate-with-cryptography
